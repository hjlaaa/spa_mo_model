      "norm": "LayerNorm",
      "residual": true,
      "use_distance_weight": true,
      "delta": 1e-08
    },
    "uot": {
      "enabled": true,
      "initial_from_modalities": true,
      "update_from_final_embedding": true,
      "epsilon_init": 0.08,
      "epsilon_update": 0.05,
      "tau_a": 1.0,
      "tau_b": 1.0,
      "max_iter": 50,
      "tol": 1e-05,
      "check_every": 10,
      "update_interval": 20,
      "topk": 10,
      "use_momentum": false,
      "momentum": 0.0,
      "normalize_total_mass": true,
      "cost": "cosine",
      "clip_cost_min": 0.0,
      "clip_cost_max": 2.0,
